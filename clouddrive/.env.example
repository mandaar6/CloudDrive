# ============================================================
# CloudDrive Environment Configuration
# Copy this to .env and fill in real values before running.
# NEVER commit .env to version control.
# ============================================================

# --- Flask ---
FLASK_SECRET_KEY=change_me_to_a_random_32_char_string
FLASK_ENV=production

# --- PostgreSQL ---
POSTGRES_USER=clouddrive
POSTGRES_PASSWORD=clouddrive_pass
POSTGRES_DB=clouddrive
DATABASE_URL=postgresql://clouddrive:clouddrive_pass@db:5432/clouddrive

# --- JWT ---
# Tokens expire after 24 hours; server-side revocation via RevokedToken table
JWT_SECRET_KEY=change_me_to_another_random_secret
JWT_EXPIRY_HOURS=24

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=us-east-1
S3_BUCKET_NAME=clouddrive-files-bucket

# --- Grafana / Loki ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
